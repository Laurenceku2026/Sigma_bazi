# --- App isolation (same Supabase project, multiple apps) ---
APP_ID=sigma_fate_v1
SUPABASE_APP_SCHEMA=app_sigma_fate

# Prefer SERVICE_ROLE for Streamlit server-side writes; keep ANON for restricted reads.
# URL / keys MUST belong to the SAME Supabase project.
SUPABASE_STOCK_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_STOCK_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=

# --- App public URL (Stripe return + password-reset email links) ---
APP_BASE_URL=https://sigma-bazi.streamlit.app

# --- Gmail SMTP (forgot-password emails from Techlife2027@gmail.com) ---
# Use a Google Account App Password (2FA required), NOT the normal login password.
# Google shows it as 4 groups with spaces; you may paste with or without spaces.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=Techlife2027@gmail.com
SMTP_PASSWORD=
SMTP_FROM=Techlife2027@gmail.com
SMTP_USE_TLS=1
