# --- App isolation (same Supabase project, multiple apps) ---
APP_ID=sigma_fate_v1
SUPABASE_APP_SCHEMA=app_sigma_fate

# Prefer SERVICE_ROLE for Streamlit server-side writes; keep ANON for restricted reads.
# URL / keys MUST belong to the SAME Supabase project.
SUPABASE_STOCK_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_STOCK_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=
